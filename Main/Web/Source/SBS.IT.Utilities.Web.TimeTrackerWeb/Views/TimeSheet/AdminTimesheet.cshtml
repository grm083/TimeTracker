@model SBS.IT.Utilities.Web.TimeTrackerWeb.Models.TimeSheetModel
@{
    ViewBag.Title = "Add";
}

@*<script src="~/Scripts/jquery.validate.min.js"></script>*@
<script src="~/Scripts/sweetalert2.all.min.js"></script>
<script src="~/Scripts/jquery.admin.timecard.js"></script>
<script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
@*<script src="~/Scripts/jquery-validate.bootstrap-tooltip.min.js"></script>*@
<style>
    .invalid {
        border: 1px solid red
    }

    #content {
        padding: 25px;
    }

    #fade {
        /*display: none;*/
        position: absolute;
        top: 0%;
        left: 0%;
        width: 100%;
        height: 100%;
        background-color: #ababab;
        z-index: 1001;
        -moz-opacity: 0.8;
        opacity: .70;
        filter: alpha(opacity=80);
    }

    #modal {
        /*display: none;*/
        position: absolute;
        top: 45%;
        left: 45%;
        width: 90px;
        height: 90px;
        padding: 30px 15px 0px;
        border: 3px solid #ababab;
        box-shadow: 1px 1px 10px #ababab;
        border-radius: 20px;
        background-color: white;
        z-index: 1002;
        text-align: center;
        overflow: auto;
    }

    #results {
        font-size: 1.25em;
        color: red
    }

    label.error {
        color: red;
    }

    

    body, html {
        margin: 0;
        padding;
        height: 100%
    }

    /* DivTable.com */
    .divTable {
        display: table;
        width: 100%;
    }

    .divTableRow {
        display: table-row;
    }

    .divTableHeading {
        background-color: black;
        display: table-header-group;
    }

    .divTableCell, .divTableHead {
        border: 1px solid black;
        display: table-cell;
        padding: 3px 10px;
    }

    .divTableHeading {
        background-color: black;
        display: table-header-group;
        font-weight: bold;
    }

    .divTableFoot {
        background-color: black;
        display: table-footer-group;
        font-weight: bold;
    }

    .divTableBody {
        /*display: table-row-group;*/
    }
</style>

<script>
    if ('@TempData["TimeCardMessage"]' != '') {
        alert('@TempData["TimeCardMessage"]');
    }

</script>


<input type="hidden" value="@ViewBag.UserId" id="hdnUserId" />

<h4 class="page-header">Time Entry</h4>
<div class="alert alert-info">
    <strong>Tip!</strong> Work Item textbox enable when you have "Other" selected in Project Item dropdown
</div>
@if (ViewBag.PendingDate != null && ViewBag.PendingDate != string.Empty && ViewBag.IsPendingAvailable == true)
{
    <div>Your time sheet entry is pending since week of<a title="Click here to navigate" href="~/Timesheet/Add?startDate=@ViewBag.PendingDate"> <b style="color:red" id="box"> @ViewBag.PendingDate</b></a></div>
}
<div id="messageBox"></div>
<div class="row">

