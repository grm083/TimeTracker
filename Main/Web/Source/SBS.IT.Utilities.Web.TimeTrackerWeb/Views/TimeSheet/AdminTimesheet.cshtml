                    <div class="col-md-1 divTableCell">
                        <input class="form-control Total readValue" id="txtTuesdayTotal" type="text" maxlength="5" disabled="disabled" value="0" tabindex="7" />
                    </div>
                    <div class="col-md-1 divTableCell">
                        <input class="form-control Total readValue" id="txtWednesdayTotal" type="text" maxlength="5" disabled="disabled" value="0" tabindex="8" />
