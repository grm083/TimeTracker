<style>
    .invalid {
        border: 1px solid red
    }

    #content {
        padding: 25px;
    }

    #fade {
        /*display: none;*/
        position: absolute;
        top: 0%;
        left: 0%;
        width: 100%;
        height: 100%;
        background-color: #ababab;
        z-index: 1001;
        -moz-opacity: 0.8;
        opacity: .70;
        filter: alpha(opacity=80);
    }



    #results {
        font-size: 1.25em;
        color: red
    }

    label.error {
        color: red;
    }


    body, html {
        margin: 0;
        padding;
        height: 100%
    }

    /* DivTable.com */
    .divTable {
        display: table;
        width: 100%;
    }

    .divTableRow {
        display: table-row;
    }

    .divTableHeading {
        background-color: black;
        display: table-header-group;
    }

    .divTableCell, .divTableHead {
        border: 1px solid black;
        display: table-cell;
        padding: 3px 10px;
    }

    .divTableHeading {
        background-color: black;
        display: table-header-group;
        font-weight: bold;
    }

    .divTableFoot {
        background-color: black;
        display: table-footer-group;
        font-weight: bold;
