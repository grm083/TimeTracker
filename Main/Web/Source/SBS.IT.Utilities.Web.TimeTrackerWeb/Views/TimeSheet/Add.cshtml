<script type="text/javascript">
    var startDate = '@ViewBag.StartDate';
    var tempteamCode = '@ViewBag.TeamCode';
    var tempTeamWorkType = '@ViewBag.TeamWorkType';
    $body = $("body");
    $(window).load(function () {
        openModal();
        initializevalues(tempteamCode, tempTeamWorkType);
        closeModal();
    });

    $(document).ready(function () {
        initializevalues(tempteamCode, tempTeamWorkType);
        $(".allowNumericWithDecimal").on("keypress keyup blur", function (event) {
            //this.value = this.value.replace(/[^0-9\.]/g,'');
            $(this).val($(this).val().replace(/[^0-9\.]/g, ''));
            if ((event.which != 46 || $(this).val().indexOf('.') != -1) && (event.which < 48 || event.which > 57)) {
                event.preventDefault();
            }
        });

        $(".allowNumericWithComma").on("keypress keyup blur", function (event) {
            var theEvent = event || window.event;
            var key = theEvent.keyCode || theEvent.which;
            key = String.fromCharCode(key);
            var regex = /[^0-9]+$/;
            if (regex.test(key)) {
                theEvent.returnValue = false;
                if (theEvent.preventDefault) theEvent.preventDefault();
            }
        });


        //setInterval(function () { blink() }, 1000);

        function blink() {
            $("#box").fadeTo(100, 0.1).fadeTo(200, 1.0);
        }

        $("#TimeSheetForm").validate({
            rules: {
                txtSunday: {
                    maxlength: 5,
                    max: 23.59,
                    number: true

                },
                txtMonday: {
                    maxlength: 5,
                    max: 23.59,
                    number: true

                },
                txTuesday: {
                    maxlength: 5,
                    max: 23.59,
                    number: true

                },
                txWednesday: {
                    maxlength: 5,
                    max: 23.59,
                    number: true

                },
                txThursday: {
                    maxlength: 5,
                    max: 23.59,
                    number: true

                },
                txtFriday: {
                    maxlength: 5,
                    max: 23.59,
                    number: true

                },
                txtSaturday: {
                    maxlength: 5,
                    max: 23.59,
                    number: true

                },
                selectProject: {
                    required: true,


                },
                selectProjectType: {
                    required: true,


                },
                selectWorkType: {
                    required: true,


                }


            },
            messages: {
                required: "Please fix the error(s) highlighted in red"

            },
            showErrors: function (errorMap, errorList) {
                if (submitted) {
                    var summary = ''; var checkCurrentRow = false;
                    if (errorList != null && errorList != undefined && errorList.length>0)
                        summary = "<label class='error'>Please fix the error(s) highlighted in red</label></br>";//"You have the following errors: </br>";
                    $.each(errorList, function (index, value) {
                        var element = errorList[index].element;
                        if (currentRowClass == '' || element.parentElement.parentElement.parentElement.className == currentRowClass) {
                            $(element).addClass("invalid");
                            checkCurrentRow = true;
                        }
                        //summary += "<label class='error'>" + this.message + "</label></br>";
                    });

                    if (checkCurrentRow) {
                        $("#messageBox").empty();
                        $("#messageBox").append(summary);
                        closeModal();

                        //$.each(errorList, function () { summary += " * " + this.message + "\n"; });

                        // alert(summary);
                        submitted = false;
                    }
                    else {
                        submitted = true;
                        //$("#TimeSheetForm").submit()
                    }
                }
             //   this.defaultShowErrors();
            },

            submitHandler: function (form) {

                form.submit();
                // LoginUser();
            }
        });

    });

</script>


