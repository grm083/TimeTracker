
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2> Time History</h2>
<div id='timeSheetweekly-notification-error' class="notificationBox notificationError" title="Error" style="display:none;"></div>
@if (SBS.IT.Utilities.Web.TimeTrackerWeb.Extension.AuthenticateExtension.IsTimeEntryEnable == 1)
{
    <div style="float:right; "><a href="~/Timesheet/Add" id="Add">Add Time</a></div>
}
<div style="clear:both; padding-top:2em;">
    @(Html.Kendo().Grid<SBS.IT.Utilities.Web.TimeTrackerWeb.Models.TimeEntryWeeklyStatusModel>()
                                                                .Name("WeeklyTimeSheetGrid")
                                                                .DataSource(dataSource => dataSource
                                                                .Ajax()
                                                                .PageSize(25)
                                                                .Read(read => read.Url(Url.Action("ReadWeeklyTimeSheetGrid")))
                                                                ).Events(events => events.DataBound("ReadWeeklyTimeSheetGrid_DataBound"))
                                                                .Columns(columns =>
                                                                {
                                                                    columns.Bound(p => p.EmployeeId).Hidden();
                                                        //columns.Bound(p => p.WeeklyUpdate).ClientTemplate("<a href='" + Url.Action("Index", "Timesheet", new { startDate = "#=kendo.toString(WeekStartDT, ' yyyy-MM-dd')#", employeeId = "#= EmployeeId#", isFilter = 1 }) + "'>#= WeeklyUpdate#</a>").HeaderHtmlAttributes(new { style = "text-align: center;" }).Sortable(false);
                                                        columns.Bound(p => p.WeeklyUpdate).HeaderHtmlAttributes(new { style = "" }).Sortable(false);
                                                                    columns.Bound(p => p.WeekWithMonth).ClientTemplate("#= SupWeekOfMonth(WeekWithMonth)#").HeaderHtmlAttributes(new { style = "" }).Sortable(false);
                                                                    columns.Bound(p => p.WeeklyTotalHours).HeaderHtmlAttributes(new { style = "" }).Sortable(false);
                                                                    columns.Bound(p => p.WeeklyStatus).HeaderHtmlAttributes(new { style = "", @class = "status" }).Sortable(false);
                                                                    columns.Command(command =>
                                                                    {
                                                                        command.Custom("gridView").Text("View").Click("gridViewClick");
                                                                        command.Custom("gridEdit").Text("Edit").Click("gridEditClick");
                                                                    }).Title("Action").HtmlAttributes(new { @style = "text-align: center;" }).HeaderHtmlAttributes(new { style = "text-align: center;width:20%;" });
                                                                }).Pageable(p => p.Refresh(true).Input(true)).Sortable(sortable => sortable.AllowUnsort(false))
                                                                    .Resizable(resizable => resizable.Columns(true))
                                                                    .Scrollable(scrollable => scrollable.Enabled(false))
    )
</div>

@section scripts{
    <script type="text/javascript">
        function gridViewClick(e) {
            var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
            if (dataItem != null && dataItem != undefined) {
                var startdate = kendo.toString(dataItem.WeekStartDT, ' yyyy-MM-dd');
                var employeeId = dataItem.EmployeeId;
                location.href = 'Index?startDate=' + startdate + '&employeeId=' + employeeId + '&isFilter=1';
            }
        }
        function gridEditClick(e) {
            var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
            if (dataItem != null && dataItem != undefined) {
                var startdate = kendo.toString(dataItem.WeekStartDT, ' yyyy-MM-dd');
                location.href = 'Add?startDate=' + startdate;
            }
        }
        function SupWeekOfMonth(data) {
            var returnString = '';
            var weekNumber = data.substring(0, 1);
            if (weekNumber == 1) {
                returnString = weekNumber + "st".sup() + data.substring(1);
            }
            else if (weekNumber == 2) {
                returnString = weekNumber + "nd".sup() + data.substring(1);
            }
            else if (weekNumber == 3) {
                returnString = weekNumber + "rd".sup() + data.substring(1);
            }
            else if (weekNumber == 4) {
                returnString = weekNumber + "th".sup() + data.substring(1);
            }
            else if (weekNumber == 5) {
                returnString = weekNumber + "th".sup() + data.substring(1);
            }
            else {
                returnString = data;
            }
            return returnString;
        }
        function ReadWeeklyTimeSheetGrid_DataBound(e) {
            var grid = $("#WeeklyTimeSheetGrid").data("kendoGrid");
            var data = grid.dataSource.data();

            grid.tbody.find('>tr').each(function () {
                var dataItem = grid.dataItem(this);
                if (dataItem.WeeklyStatus != null && dataItem.WeeklyStatus != '' && dataItem.WeeklyStatus == 'Pending') {
                    var cells = $(this).find("td[role=gridcell]");
                    var cell = $(cells[4]);
                    cell.css("color", "red");
                }
                if (dataItem.WeeklyStatus != null && dataItem.WeeklyStatus != '' && dataItem.WeeklyStatus == 'Completed') {
                    var cells = $(this).find("td[role=gridcell]");
                    var cell = $(cells[4]);
                    cell.css("color", "green");
                }

                //if (dataItem.WeeklyStatus != null && dataItem.WeeklyStatus != '' && dataItem.WeeklyStatus == 'Completed') {
                //    $(this).css('background-color', 'green');
                //}
            });
        }
    </script>
}
