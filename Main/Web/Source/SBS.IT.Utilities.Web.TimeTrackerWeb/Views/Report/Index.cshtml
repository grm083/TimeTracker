@using ReportViewerForMvc;
@model SBS.IT.Utilities.Web.TimeTrackerWeb.Models.ReportViewModel
@{
    ViewBag.Title = "Index";
}

<h2>Reports</h2>

<div class="">
    <ul class="nav nav-tabs">
        @foreach (var hdr in Model.ReportHeader)
        {
            <li class="dropdown">
                <a class="dropdown-toggle" data-toggle="dropdown" href="#">@Html.DisplayFor(m => hdr) <span class="caret"></span></a>
                <ul class="dropdown-menu">
                    @foreach (var report in Model.ReportList)
                    {

                        if (hdr.Equals(report.ReportCategory, StringComparison.InvariantCultureIgnoreCase))
                        {
                            <li>
                                @Html.ActionLink(report.DisplayName, "OpenReport", "Report", new { reportFolder = report.ReportFolder, reportPath = report.ReportPath, reportServer = report.ReportServerURL }, null)
                            </li>
                        }
                    }
                </ul>
            </li>
        }
    </ul>
</div>
<br />
@if (Model.IsReportVisible != false)
{
    <div class="col-lg-12" id="reports">
        @*<iframe runat="server" id="Reports" src="~/ReportViewer/ReportViewer.aspx" width="100%" height="750px"></iframe>*@
        @Html.ReportViewer(ViewBag.ReportViewer as Microsoft.Reporting.WebForms.ReportViewer)
    </div>
}

<style>
    #reports iframe {
        width: 100% !important;
       height:750px !important;
    }
</style>